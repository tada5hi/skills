{
    "type": "module",
    "private": true,
    "description": "tada5hi's curated collection of agent skills.",
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/skills.git"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "lint": "eslint --ext .js,.ts,.mjs,.mts .",
        "lint:fix": "npm run lint -- --fix",
        "skills": "tsx src/cli.ts",
        "skills:init": "tsx src/cli.ts init",
        "skills:sync": "tsx src/cli.ts sync",
        "skills:check": "tsx src/cli.ts check",
        "skills:cleanup": "tsx src/cli.ts cleanup",
        "skills:link": "tsx src/cli.ts link",
        "test": "vitest run --config test/vitest.config.ts"
    },
    "devDependencies": {
        "@tada5hi/tsconfig": "^0.7.2",
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "eslint": "^10.1.0",
        "tsx": "^4.19.4",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    },
    "lint-staged": {
        "*.{js,ts,mjs,mts}": "eslint --fix"
    }
}
